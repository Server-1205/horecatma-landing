---
interface Props {
  title: string;
  subtitle?: string;
  class?: string;
}

const { title, subtitle, class: className = '' } = Astro.props;
---

<div class={`text-center mb-16 ${className}`}>
  <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">{title}</h2>
  {subtitle && (
    <p class="text-lg text-gray-500 max-w-2xl mx-auto">{subtitle}</p>
  )}
</div>
