---
interface Props {
  variant?: 'orange' | 'green' | 'blue' | 'gray';
  class?: string;
}

const { variant = 'orange', class: className = '' } = Astro.props;

const variants = {
  orange: 'bg-brand-100 text-brand-700',
  green: 'bg-green-100 text-green-700',
  blue: 'bg-blue-100 text-blue-700',
  gray: 'bg-gray-100 text-gray-600',
};

const classes = `inline-flex items-center px-3 py-1 rounded-full text-sm font-medium ${variants[variant]} ${className}`;
---

<span class={classes}>
  <slot />
</span>
