---
interface Props {
  hover?: boolean;
  class?: string;
}

const { hover = true, class: className = '' } = Astro.props;

const classes = `bg-white rounded-xl border border-gray-100 p-6 ${hover ? 'shadow-sm hover:shadow-lg hover:border-brand-200 transition-all duration-300' : ''} ${className}`;
---

<div class={classes}>
  <slot />
</div>
