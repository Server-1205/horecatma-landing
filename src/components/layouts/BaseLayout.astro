---
import Logo from '../ui/Logo.astro';
import Button from '../ui/Button.astro';
import LanguageSwitcher from '../islands/LanguageSwitcher';
import { SITE, SOCIALS } from '../../lib/constants';
import { type Locale, getTranslations, localeNames } from '../../i18n/index';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale, title, description } = Astro.props;
const t = getTranslations(locale);
const otherLocale: Locale = locale === 'uz' ? 'ru' : 'uz';
const otherPath = otherLocale === 'uz' ? '/' : `/${otherLocale}/`;
const currentPath = Astro.url.pathname;

const pageTitle = title ?? t.hero.headline + ' ' + t.hero.headlineHighlight;
const pageDescription = description ?? t.hero.subheadline;
const ogImage = `${SITE.url}/og-image.png`;

const navLinks = [
  { href: '#features', label: t.nav.features },
  { href: '#how-it-works', label: t.nav.howItWorks },
  { href: '#pricing', label: t.nav.pricing },
  { href: '#faq', label: t.nav.faq },
];

const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "HorecaTMA",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Telegram",
  "description": pageDescription,
  "url": `${SITE.url}${currentPath}`,
  "offers": {
    "@type": "Offer",
    "price": "10",
    "priceCurrency": "USD",
    "priceValidUntil": "2026-12-31"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "ratingCount": "50"
  }
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "HorecaTMA",
  "url": SITE.url,
  "inLanguage": ["uz", "ru"],
  "potentialAction": {
    "@type": "SearchAction",
    "target": `${SITE.url}/?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta name="robots" content="index, follow" />
  <meta name="keywords" content="кафе, ресторан, Telegram Mini App, QR меню, заказы еды, доставка, Узбекистан, Toshkent, меню для кафе, POS система" />

  <!-- Open Graph -->
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`${SITE.url}${currentPath}`} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="HorecaTMA" />
  <meta property="og:locale" content={locale === 'uz' ? 'uz_UZ' : 'ru_RU'} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- i18n -->
  <link rel="alternate" hreflang="uz" href={`${SITE.url}/`} />
  <link rel="alternate" hreflang="ru" href={`${SITE.url}/ru/`} />
  <link rel="alternate" hreflang="x-default" href={`${SITE.url}/`} />
  <link rel="canonical" href={`${SITE.url}${currentPath}`} />

  <!-- Performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
</head>
<body class="antialiased">
  <!-- Navbar -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-xl border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <Logo />

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-8">
          {navLinks.map((link) => (
            <a href={link.href} class="text-sm text-gray-500 hover:text-gray-900 transition-colors font-light">
              {link.label}
            </a>
          ))}
        </div>

        <div class="hidden md:flex items-center gap-4">
          <LanguageSwitcher currentLocale={locale} client:load />
          <Button href={SITE.botUrl} size="sm">
            {t.nav.cta}
          </Button>
        </div>

        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-600 hover:text-gray-900" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100">
      <div class="px-4 py-4 space-y-3">
        {navLinks.map((link) => (
          <a href={link.href} class="block text-gray-600 hover:text-gray-900 py-2">
            {link.label}
          </a>
        ))}
        <div class="pt-3 border-t border-gray-100 flex flex-col gap-3">
          <LanguageSwitcher currentLocale={locale} client:load />
          <Button href={SITE.botUrl} size="sm" class="w-full">
            {t.nav.cta}
          </Button>
        </div>
      </div>
    </div>
  </nav>

  <!-- Main content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-gray-900 text-gray-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
        <!-- Brand -->
        <div class="md:col-span-1">
          <Logo class="mb-4" />
          <p class="text-sm text-gray-400 mt-4">{t.footer.description}</p>
          <div class="flex gap-4 mt-6">
            <a href={SOCIALS.telegram} class="text-gray-400 hover:text-white transition-colors" aria-label="Telegram">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            </a>
            <a href={SOCIALS.instagram} class="text-gray-400 hover:text-white transition-colors" aria-label="Instagram">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
            </a>
          </div>
        </div>

        <!-- Product -->
        <div>
          <h3 class="text-white font-semibold mb-4">{t.footer.product}</h3>
          <ul class="space-y-3 text-sm">
            <li><a href="#features" class="hover:text-white transition-colors">{t.nav.features}</a></li>
            <li><a href="#pricing" class="hover:text-white transition-colors">{t.nav.pricing}</a></li>
            <li><a href="#how-it-works" class="hover:text-white transition-colors">{t.nav.howItWorks}</a></li>
          </ul>
        </div>

        <!-- Company -->
        <div>
          <h3 class="text-white font-semibold mb-4">{t.footer.company}</h3>
          <ul class="space-y-3 text-sm">
            <li><a href={SITE.botUrl} class="hover:text-white transition-colors">{t.footer.contacts}</a></li>
            <li><a href="#faq" class="hover:text-white transition-colors">{t.footer.faq}</a></li>
          </ul>
        </div>

        <!-- Support -->
        <div>
          <h3 class="text-white font-semibold mb-4">{t.footer.support}</h3>
          <ul class="space-y-3 text-sm">
            <li><a href={SITE.supportUrl} class="hover:text-white transition-colors">Telegram</a></li>
            <li><a href="#faq" class="hover:text-white transition-colors">{t.footer.faq}</a></li>
          </ul>
        </div>
      </div>

      <div class="border-t border-gray-800 mt-12 pt-8 text-sm text-gray-500 text-center">
        <p>&copy; 2026 HorecaTMA. {t.footer.copyright} 🇺🇿</p>
      </div>
    </div>
  </footer>

  <script>
    const menuBtn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    menuBtn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });

    // Close mobile menu on link click
    menu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => menu?.classList.add('hidden'));
    });
  </script>
</body>
</html>

<style is:global>
  @import '../../styles/global.css';
</style>
