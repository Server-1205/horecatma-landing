---
import Button from '../ui/Button.astro';
import { SITE } from '../../lib/constants';
import { type Locale, getTranslations } from '../../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section class="py-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-br from-brand-500 via-brand-500 to-brand-600">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">{t.cta.title}</h2>
    <p class="text-brand-100 text-lg mb-8 max-w-xl mx-auto">{t.cta.subtitle}</p>
    <Button href={SITE.botUrl} variant="secondary" size="lg" class="bg-white text-brand-600 hover:bg-brand-50">
      {t.cta.cta}
      <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
      </svg>
    </Button>
    <p class="text-brand-200 text-sm mt-6">{t.cta.support} <a href={SITE.supportUrl} class="underline hover:text-white">@HorecaTMA_support</a></p>
  </div>
</section>
