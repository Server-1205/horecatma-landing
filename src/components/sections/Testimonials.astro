---
import SectionHeading from '../ui/SectionHeading.astro';
import { type Locale, getTranslations } from '../../i18n/index';
import { TESTIMONIALS } from '../../lib/constants';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const initials = (name: string) => name.split(',').pop()?.trim().charAt(0) ?? '?';
---

<section class="py-24 px-4 sm:px-6 lg:px-8 bg-white">
  <div class="max-w-7xl mx-auto">
    <SectionHeading title={t.testimonials.title} subtitle={t.testimonials.rating} />

    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      {TESTIMONIALS.map((testimonial, i) => (
        <div class={`bg-white rounded-xl border border-gray-100 p-8 hover:shadow-lg hover:shadow-gray-100/80 transition-all duration-300 animate-slide-up stagger-${i + 1}`}>
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {[1, 2, 3, 4, 5].map(() => (
              <svg class="w-5 h-5 text-brand-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <p class="text-gray-600 text-sm leading-relaxed mb-6 font-light">"{testimonial.text[locale]}"</p>

          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center font-medium text-sm">
              {initials(testimonial.author[locale])}
            </div>
            <div>
              <div class="text-sm font-medium text-gray-900">{testimonial.author[locale]}</div>
              <div class="text-xs text-gray-500 font-light">{testimonial.city[locale]}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
