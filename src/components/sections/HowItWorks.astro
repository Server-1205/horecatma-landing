---
import SectionHeading from '../ui/SectionHeading.astro';
import { type Locale, getTranslations } from '../../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const steps = t.howItWorks.steps;
---

<section id="how-it-works" class="py-24 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-brand-50/50 to-white">
  <div class="max-w-7xl mx-auto">
    <SectionHeading title={t.howItWorks.title} subtitle={t.howItWorks.subtitle} />

    <div class="relative max-w-5xl mx-auto">
      <!-- Connection line (desktop) -->
      <div class="hidden lg:block absolute top-24 left-[16%] right-[16%] h-px bg-gradient-to-r from-brand-200 via-brand-300 to-brand-200"></div>

      <div class="grid lg:grid-cols-3 gap-8">
        {steps.map((step, i) => (
          <div class="relative text-center animate-slide-up stagger-${i + 1}">
            <!-- Image -->
            <div class="relative z-10 mx-auto mb-6 w-48 h-40 rounded-2xl overflow-hidden shadow-lg shadow-brand-200/20">
              <img
                src={i === 0 ? '/images/food-plov.jpg' : i === 1 ? '/images/qr-scan.jpg' : '/images/kitchen.jpg'}
                alt={step.title}
                class="w-full h-full object-cover"
                loading="lazy"
              />
              <!-- Step number badge -->
              <div class="absolute top-2 left-2 w-8 h-8 bg-brand-500 text-white rounded-full flex items-center justify-center text-sm font-bold shadow-md">
                {step.number}
              </div>
            </div>
            <h3 class="text-xl font-light text-gray-900 mb-3 tracking-[-0.01em]">{step.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed max-w-xs mx-auto font-light">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
