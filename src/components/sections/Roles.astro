---
import SectionHeading from '../ui/SectionHeading.astro';
import { type Locale, getTranslations } from '../../i18n/index';
import { ROLES } from '../../lib/constants';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const iconMap: Record<string, string> = {
  User: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
  Crown: 'M5 16l-1-9 5 3 3-5 3 5 5-3-1 9H5zm0 0v2a2 2 0 002 2h10a2 2 0 002-2v-2',
  ChefHat: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 14H6v-2h6v2zm4-4H6V8h10v4z',
  ConciergeBell: 'M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9zM13.73 21a2 2 0 01-3.46 0',
};

const roleColors = [
  { bg: 'bg-blue-50', icon: 'bg-blue-100 text-blue-600', border: 'border-blue-100' },
  { bg: 'bg-amber-50', icon: 'bg-amber-100 text-amber-600', border: 'border-amber-100' },
  { bg: 'bg-emerald-50', icon: 'bg-emerald-100 text-emerald-600', border: 'border-emerald-100' },
  { bg: 'bg-purple-50', icon: 'bg-purple-100 text-purple-600', border: 'border-purple-100' },
];
---

<section id="roles" class="py-24 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-white to-brand-50/30">
  <div class="max-w-7xl mx-auto">
    <SectionHeading title={t.roles.title} />

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
      {ROLES.map((role, i) => (
        <div class={`${roleColors[i].bg} rounded-xl border ${roleColors[i].border} p-6 hover:shadow-lg transition-all duration-300 animate-slide-up stagger-${i + 1}`}>
          <div class={`w-14 h-14 ${roleColors[i].icon} rounded-xl flex items-center justify-center mb-5`}>
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={iconMap[role.icon]} />
            </svg>
          </div>
          <h3 class="text-xl font-light text-gray-900 mb-4 tracking-[-0.01em]">{role.title[locale]}</h3>
          <ul class="space-y-3">
            {role.benefits[locale].map((benefit) => (
              <li class="flex items-start gap-2.5 text-sm text-gray-600">
                <svg class="w-4 h-4 text-gray-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {benefit}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
